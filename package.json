{
  "name": "pandoc-vscode",
  "displayName": "Pandoc Extension for VSCode",
  "description": "Convert Markdown files to DOCX, HTML and PDF using Pandoc",
  "version": "0.0.1",
  "publisher": "AhmedYoussef",
  "icon": "pandoc.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ayoussef-insight/pandoc-vscode.git"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "submenus": [
      {
        "id": "pandoc.explorerSubmenu",
        "label": "Pandoc"
      },
      {
        "id": "pandoc.explorerSubmenuFolder",
        "label": "Pandoc"
      }
    ],
    "commands": [
      {
        "command": "pandoc.convertToDocx",
        "title": "Convert Markdown to DOCX",
        "category": "Pandoc"
      },
      {
        "command": "pandoc.convertToHtml",
        "title": "Convert Markdown to HTML",
        "category": "Pandoc"
      },
      {
        "command": "pandoc.convertToPdf",
        "title": "Convert Markdown to PDF",
        "category": "Pandoc"
      },
      {
        "command": "pandoc.convertFolderToDocx",
        "title": "Convert All Markdown to DOCX",
        "category": "Pandoc"
      },
      {
        "command": "pandoc.convertFolderToHtml",
        "title": "Convert All Markdown to HTML",
        "category": "Pandoc"
      },
      {
        "command": "pandoc.convertFolderToPdf",
        "title": "Convert All Markdown to PDF",
        "category": "Pandoc"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "pandoc.convertToDocx",
          "when": "editorLangId == markdown"
        },
        {
          "command": "pandoc.convertToHtml",
          "when": "editorLangId == markdown"
        },
        {
          "command": "pandoc.convertToPdf",
          "when": "editorLangId == markdown"
        }
      ],
      "editor/context": [
        {
          "submenu": "pandoc.explorerSubmenu",
          "group": "navigation",
          "when": "editorLangId == markdown"
        }
      ],
      "explorer/context": [
        {
          "submenu": "pandoc.explorerSubmenu",
          "group": "navigation",
          "when": "resourceExtname == .md"
        },
        {
          "submenu": "pandoc.explorerSubmenuFolder",
          "group": "navigation",
          "when": "explorerResourceIsFolder"
        }
      ],
      "pandoc.explorerSubmenu": [
        {
          "command": "pandoc.convertToDocx",
          "group": "pandoc@1"
        },
        {
          "command": "pandoc.convertToHtml",
          "group": "pandoc@2"
        },
        {
          "command": "pandoc.convertToPdf",
          "group": "pandoc@3"
        }
      ],
      "pandoc.explorerSubmenuFolder": [
        {
          "command": "pandoc.convertFolderToDocx",
          "group": "pandocFolder@1"
        },
        {
          "command": "pandoc.convertFolderToHtml",
          "group": "pandocFolder@2"
        },
        {
          "command": "pandoc.convertFolderToPdf",
          "group": "pandocFolder@3"
        }
      ]
    },
    "configuration": {
      "title": "Pandoc Converter",
      "properties": {
        "pandoc.path": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to the pandoc executable. If empty, 'pandoc' from PATH is used."
        },
        "pandoc.outputDir": {
          "type": "string",
          "default": "",
          "description": "Default output directory. Leave empty to use the source file's directory. Relative paths are resolved against the workspace folder."
        },
        "pandoc.docx.customArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Pandoc arguments for DOCX conversion. Example: ['--reference-doc=template.docx', '--number-sections']"
        },
        "pandoc.docx.singleFileCustomArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional Pandoc arguments for DOCX conversion when converting a single file. These are merged with customArgs."
        },
        "pandoc.docx.multipleFilesCustomArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional Pandoc arguments for DOCX conversion when converting multiple files in a folder. These are merged with customArgs."
        },
        "pandoc.html.customArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Pandoc arguments for HTML conversion. Example: ['--standalone', '--css=style.css']"
        },
        "pandoc.html.singleFileCustomArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional Pandoc arguments for HTML conversion when converting a single file. These are merged with customArgs."
        },
        "pandoc.html.multipleFilesCustomArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional Pandoc arguments for HTML conversion when converting multiple files in a folder. These are merged with customArgs."
        },
        "pandoc.pdf.customArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Pandoc arguments for PDF conversion. Example: ['--pdf-engine=xelatex', '--number-sections']"
        },
        "pandoc.pdf.singleFileCustomArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional Pandoc arguments for PDF conversion when converting a single file. These are merged with customArgs."
        },
        "pandoc.pdf.multipleFilesCustomArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional Pandoc arguments for PDF conversion when converting multiple files in a folder. These are merged with customArgs."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "lint": "eslint src --ext ts",
    "publish": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^3.6.2",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
